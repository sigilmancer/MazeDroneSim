@page "/"
@using MazeDroneSim

<PageTitle>3D Maze Simulation Dashboard</PageTitle>

<div style="padding: 20px; font-family: sans-serif; background-color: #1e1e24; color: #f5f5f5; min-height: 100vh;">
    <h1 style="color: #4cc9f0; margin-bottom: 5px;">3D Maze Drone Simulation</h1>
    <p style="color: #9e9e9e; margin-top: 0; margin-bottom: 25px;">Visualising the finite 3x3x3 grid system.</p>

    <div style="margin-bottom: 25px; display: flex; gap: 15px; align-items: center;">
        <button @onclick="GenerateNewMaze" disabled="@isSearching"
                style="padding: 12px 24px; font-weight: bold; background-color: #4cc9f0; color: #1e1e24; border: none; border-radius: 4px; cursor: isSearching ? 'not-allowed' : 'pointer'; opacity: isSearching ? 0.5 : 1;">
            🔄 Generate New Maze Layout
        </button>

        <button @onclick="StartDroneSearch" disabled="@(isSearching || droneEngine?.IsComplete == true)"
                style="padding: 12px 24px; font-weight: bold; background-color: #4cc9f0; color: #1e1e24; border: none; border-radius: 4px; cursor: (isSearching || droneEngine?.IsComplete == true) ? 'not-allowed' : 'pointer'; opacity: (isSearching || droneEngine?.IsComplete == true) ? 0.5 : 1;">
            ⚡ Launch Autonomous Drone Pathfinding
        </button>

        @if (isSearching)
        {
            <span style="color: #4cc9f0; font-weight: bold; animation: blink 1s infinite;">🛰️ Drone is exploring the layout...</span>
        }
        else if (droneEngine?.IsComplete == true)
        {
            <span style="color: #4cc9f0; font-weight: bold;">🎉 Treasure Recovered Successfully!</span>
        }
    </div>

    @if (Generator.Rooms.Any())
    {
        <div style="display: flex; gap: 30px; flex-wrap: wrap;">
            @for (int z = 0; z < 3; z++)
            {
                var floorIndex = z;
                <div style="background-color: #2a2a35; padding: 20px; border-radius: 8px; border: 1px solid #3f3f50; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
                    <h3 style="margin-top: 0; margin-bottom: 15px; color: #f72585; text-align: center; letter-spacing: 1px;">Floor Z = @floorIndex</h3>
                    
                    <div style="display: grid; grid-template-columns: repeat(3, 90px); gap: 15px;">
                        @for (int y = 2; y >= 0; y--)
                        {
                            @for (int x = 0; x < 3; x++)
                            {
                                var currentCoord = new Coordinate(x, y, floorIndex);
                                var room = Generator.Rooms[currentCoord];
                                
                                var isCurrentDronePos = droneEngine?.ActualPhysicalPosition == currentCoord;
                                var isTreasure = Generator.TreasurePosition == currentCoord;
                                
                                // Determine if this specific room has been flagged by the drone's memory
                                string roomBg = "#3b3b4f"; 
                                if (isCurrentDronePos)
                                {
                                    roomBg = "#4cc9f0"; 
                                }
                                else if (isSearching && droneEngine != null)
                                {
                                    // Map back the physical location to what the drone mapped relatively
                                    var relX = currentCoord.X - Generator.DroneStartPosition.X;
                                    var relY = currentCoord.Y - Generator.DroneStartPosition.Y;
                                    var relZ = currentCoord.Z - Generator.DroneStartPosition.Z;
                                    
                                    if (droneEngine.VisitedMemory.Contains((relX, relY, relZ)))
                                    {
                                        roomBg = "#2d3748"; 
                                    }
                                }

                                <div style="width: 90px; height: 90px; position: relative; background-color: @roomBg; display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 11px; font-weight: bold; border-radius: 6px; transition: background-color 0.2s ease;
                                            border-top: @(room.Doors[0] ? "2px dashed rgba(76, 201, 240, 0.4)" : "4px solid #f72585");
                                            border-right: @(room.Doors[1] ? "2px dashed rgba(76, 201, 240, 0.4)" : "4px solid #f72585");
                                            border-bottom: @(room.Doors[3] ? "2px dashed rgba(76, 201, 240, 0.4)" : "4px solid #f72585");
                                            border-left: @(room.Doors[4] ? "2px dashed rgba(76, 201, 240, 0.4)" : "4px solid #f72585");">
                                    
                                    <span style="color: #7a7a9a; font-size: 9px; position: absolute; top: 5px; left: 5px;">@x,@y,@floorIndex</span>
                                    
                                    @if (isCurrentDronePos)
                                    {
                                        <span style="font-size: 26px; z-index: 2; color: #1e1e24;">🚀</span>
                                    }
                                    else if (isTreasure)
                                    {
                                        <span style="font-size: 24px;">💎</span>
                                    }

                                    <div style="font-size: 10px; color: #4cc9f0; position: absolute; bottom: 5px; display: flex; gap: 8px;">
                                        @if (room.Doors[2]) { <span>▲</span> }
                                        @if (room.Doors[5]) { <span>▼</span> }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    @("@keyframes") blink {
        0% { opacity: 1; }
        50% { opacity: 0.4; }
        100% { opacity: 1; }
    }
</style>

@code {
    private MazeGenerator Generator = new();
    private DroneEngine? droneEngine;
    private bool isSearching = false;

    protected override void OnInitialized()
    {
        GenerateNewMaze();
    }

    private void GenerateNewMaze()
    {
        isSearching = false;
        Generator.Generate3x3x3Maze();
        // Initialize the drone engine with a state-refresh callback loop
        droneEngine = new DroneEngine(Generator, async () => await InvokeAsync(StateHasChanged));
    }

    private async Task StartDroneSearch()
    {
        if (droneEngine == null || isSearching) return;
        
        isSearching = true;
        await droneEngine.FindTreasure();
        isSearching = false;
    }
}
